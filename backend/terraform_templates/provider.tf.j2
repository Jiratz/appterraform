terraform {
  required_providers {
    oci = {
      source  = "oracle/oci"
      version = "~> 6.0"
    }
  }
}

provider "oci" {
  tenancy_ocid     = "{{ tenancy_ocid }}"
  user_ocid        = "{{ user_ocid }}"
  fingerprint      = "{{ fingerprint }}"
  private_key_path = "{{ private_key_path }}"
  region           = "{{ region }}"
}
