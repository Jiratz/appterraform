resource "oci_load_balancer_load_balancer" "lb" {
  compartment_id = "{{ compartment_id }}"
  display_name   = "terraform-load-balancer"
  shape          = "flexible"
  subnet_ids     = ["{{ subnet_id }}"]
  is_private     = false

  shape_details {
    minimum_bandwidth_in_mbps = 10
    maximum_bandwidth_in_mbps = 100
  }
}

resource "oci_load_balancer_backend_set" "lb_backend_set" {
  load_balancer_id = oci_load_balancer_load_balancer.lb.id
  name             = "terraform-backend-set"
  policy           = "ROUND_ROBIN"

  health_checker {
    protocol = "HTTP"
    port     = 80
    url_path = "/"
  }
}

resource "oci_load_balancer_listener" "lb_listener" {
  load_balancer_id         = oci_load_balancer_load_balancer.lb.id
  name                     = "terraform-listener"
  default_backend_set_name = oci_load_balancer_backend_set.lb_backend_set.name
  port                     = 80
  protocol                 = "HTTP"
}

output "load_balancer_ip" {
  value = oci_load_balancer_load_balancer.lb.ip_address_details[0].ip_address
}
